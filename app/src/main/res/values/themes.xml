<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RocketLauncher" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:colorPrimary">#0088CC</item>
        <item name="android:colorPrimaryDark">#006699</item>
    </style>

    <!-- Полноэкранный splash до первого кадра Compose -->
    <style name="Theme.RocketLauncher.Splash" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_window</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>
