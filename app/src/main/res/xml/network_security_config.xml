<?xml version="1.0" encoding="utf-8"?>
<!-- Явная политика TLS/cleartext. Сейчас cleartext разрешён (произвольные HTTP-серверы пользователя). При переходе на только HTTPS — ограничьте domain-config. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
