# Скопируйте в keystore.properties в корне проекта и заполните значения.
# Файл keystore.properties не коммитьте (он в .gitignore).
#
# Для загрузки AAB в Google Play собирайте с обязательным ключом:
#   gradlew bundleRelease -PrequireReleaseKeystore=true
#
# storeFile — путь к .jks / .keystore относительно корня репозитория (можно со слэшем /).
# Остальные поля — как при создании хранилища (keytool или Android Studio).

storeFile=release-upload.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=release
keyPassword=YOUR_KEY_PASSWORD
